{% include head.liquid %}

<style>
  /* ==========================================================================
     WAVESLAB CORE GLOBAL LAYOUT OVERRIDES
     ========================================================================== */

  /* Navigation Bar Background */
  .navbar, #navbar {
    background-color: #0f3460 !important; /* Premium Waves Lab Dark Blue */
    border-bottom: 1px solid rgba(255, 255, 255, 0.1) !important;
    box-shadow: 0 4px 12px rgba(15, 52, 96, 0.1) !important;
  }

  /* Navigation Menu Link Styling */
  .navbar .nav-link, #navbar .nav-link {
    color: rgba(255, 255, 255, 0.85) !important;
    font-weight: 500 !important;
  }

  /* Hover & Active Page Visibility States */
  .navbar .nav-link:hover, 
  .navbar .nav-item.active .nav-link,
  #navbar .nav-link:hover {
    color: #ffffff !important;
    text-shadow: 0 0 8px rgba(255, 255, 255, 0.4) !important;
  }

  /* Dropdown Arrows, Search Icons, Mobile Hamburger Bars */
  .navbar #search-toggle, 
  .navbar .dropdown-toggle, 
  .navbar i, 
  .navbar .navbar-toggler-icon,
  .navbar .navbar-toggler {
    color: rgba(255, 255, 255, 0.85) !important;
  }

  /* Global Layout Footer Continuity */
  footer.fixed-bottom {
    background-color: #0f3460 !important; 
    border-top: 1px solid rgba(255, 255, 255, 0.1) !important;
  }

  footer.fixed-bottom, 
  footer.fixed-bottom span, 
  footer.fixed-bottom a {
    color: rgba(255, 255, 255, 0.8) !important;
  }

  footer.fixed-bottom a {
    text-decoration: underline !important;
  }

  footer.fixed-bottom a:hover {
    color: #ffffff !important;
  }
</style>